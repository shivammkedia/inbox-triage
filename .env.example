# LLM (Groq is the free primary)
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Models
CLASSIFIER_MODEL=llama-3.1-8b-instant
DRAFTER_MODEL=llama-3.3-70b-versatile

# Gmail OAuth (run scripts/bootstrap_gmail_oauth.py once to get the refresh token)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Behavior
DRY_RUN=true
MAX_EMAILS_PER_RUN=20
LOOKBACK_HOURS=2
